{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A baby product available in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the product." },
        "name": { "type": "string", "description": "Name of the product." },
        "price": { "type": "number", "description": "Price in GHS." },
        "category": { "type": "string", "description": "Category of the product." },
        "ageRange": { "type": "string", "description": "Target age range." },
        "image": { "type": "string", "description": "URL or local path to the product image." },
        "description": { "type": "string", "description": "Detailed description of the product." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the product was added." }
      },
      "required": ["name", "price", "category", "ageRange", "image", "description"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Collection of baby products."
    }
  }
}
