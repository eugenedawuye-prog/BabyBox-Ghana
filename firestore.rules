rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - id: string (required) - Unique identifier
    //   - name: string (required, 1-100 chars) - Product name
    //   - price: number (required, > 0) - Price in GHS
    //   - category: string (required) - Product category
    //   - ageRange: string (required) - Target age range
    //   - image: string (required) - URL or local path
    //   - description: string (required, 1-1000 chars) - Product description
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "eugenedawuye@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidProduct(data) {
      return hasRequiredFields(['name', 'price', 'category', 'ageRange', 'image', 'description', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'name', 'price', 'category', 'ageRange', 'image', 'description', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price > 0 &&
             data.category is string &&
             data.ageRange is string &&
             data.image is string &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
